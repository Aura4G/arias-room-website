---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Aria's Room" bgColor="bg-white">
	<div class="flex flex-col items-center justify-center min-h-[80vh] text-center gap-6">
		<h1 class="font-display text-5xl font-bold position: fixed top-40">Aria's Room </h1>		
		<div class="flex justify-between w-full px-4 md:px-[15%]">
			<div class="flex flex-col items-center gap-2">
				<a href="/blog/" class=" px-10 py-7 border border-solid border-blue-600 bg-white text-xl text-blue-400 hover:bg-sky-200 ">Blog</a>
				<span class="text-2xl text-sky-400">↓</span>
			</div>
			<div class="flex flex-col items-center gap-2">
				<a href="/about/" class=" px-10 py-7 border border-solid border-red-600 bg-white text-xl text-red-400 hover:bg-red-200 ">About Me!</a>
				<span class="text-2xl text-red-400">↓</span>
			</div>
			<div class="flex flex-col items-center gap-2">
				<a href="/projects/" class=" px-10 py-7 border border-solid border-black-600 text-xl text-black-600 font-mono hover:bg-black hover:border-green-400 hover:text-green-400 ">My Projects</a>
				<span class="text-2xl text-black-400">↓</span>
			</div>
		</div>
	</div>
</Layout>
