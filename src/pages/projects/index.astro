---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";

const projects = await getCollection('projects');
const tagColors: Record<string, string> = {
    test: 'bg-gray-100 text-gray-700',
    'C': 'bg-blue-100 text-blue-700',
    'C++': 'bg-pink-100 text-pink-700',
    Videogame: 'bg-orange-100 text-orange-700',
    Website: 'bg-yellow-100 text-yellow-700',
    Conversation: 'bg-green-100 text-green700'
}
const defaultTagColor = 'bg-lime-100 text-lime-700'
---
<Layout title="Aria's Projects" bgColor="bg-black">
    <div style="max-width: 700px; margin: 0 auto; padding: 2rem 1rem;" class="flex flex-col items-center">
        <h1 class="typing text-4xl font-mono mb-8 text-green-400 text-center underline" style={{"--chars": 11, "--speed": '1s'}}>My Projects</h1>
        <div class="shadow-md border border-green-400 rounded-lg p-2 w-full">
            <ul class="divide-y divide-green-400">
                {projects.map(project => (
                    <li class="py-3">
                        <a href={`/projects/${project.id}/`} class="post-row">
                            <span class="title font-mono">{project.data.title}</span>
                            <div class="meta-row">
                                <span class="description font-mono" data-text={project.data.description}>{'*'.repeat(project.data.description.length)}</span>
                                <div class="tags font-mono">
                                    {project.data.tags?.map(tag => (
                                        <span class={`tag-badge ${tagColors[tag] ?? defaultTagColor}`}>{tag}</span>
                                    ))}
                                </div>
                            </div>
                        </a>
                    </li>
                ))}
            </ul>
        </div>
    </div>
</Layout>

<style>
    .typing {
        overflow: hidden;
        white-space: nowrap;
        border-right: 2px solid;
        width: 0;
        animation: typing var(--speed, 1.5s) steps(var(--chars, 10), end) forwards, blink 0.8s step-end infinite;
    }

    @keyframes typing {
        from {
            width 0;
        }
        to {
            width: calc(var(--chars) * 1ch);
        }
    }

    @keyframes blink {
        50% {
            border-color: transparent;
        }
    }

    .post-row {
        display: grid;
        grid-template-rows: auto auto;
        gap: 0.5rem;
        align-items:start;
        color: white;
        font-size: 1.125rem;
    }
    .title {
        font-weight: 500;
    }
    .post-row:hover .title {
        text-decoration: underline;
    }
    .meta-row {
        display:flex;
        justify-content: space-between;
        width: 100%;
        align-items: flex-start;
    }
    .description {
        font-weight: 300;
        color: #05df72;
        font-size: 0.875rem;
    }
    .tags {
        display: flex;
        gap: 0.4rem;
        flex-wrap: wrap;
        justify-content: flex-end;
    }
    .tag-badge {
        font-size: 0.75rem;
        padding: 0.15rem 0.5rem;
        border-radius: 0.375rem;
        font-weight: 500;
    }    
</style>

<script>
    document.querySelectorAll('.post-row').forEach(row => {
        const descSpan = row.querySelector<HTMLElement>('.description');
        if (!descSpan) return;

        const realText = descSpan.dataset.text ?? '';
        const maskText = '*'.repeat(realText.length);
        let typeInterval: ReturnType<typeof setInterval>;
        let index = 0;

        row.addEventListener('mouseenter', () => {
            clearInterval(typeInterval);
            index = 0;
            typeInterval = setInterval(() => {
                index++;
                descSpan.textContent = realText.slice(0, index) + maskText.slice(index);
                if (index >= realText.length) clearInterval(typeInterval);
            }, 50);
        });

        row.addEventListener('mouseleave', () => {
            clearInterval(typeInterval);
            descSpan.textContent = maskText;
        });
    });
</script>